# Path the engine's Python code reads (used when running natively, outside Docker).
# Inside Docker, this is overridden to /models/ollama by docker-compose.yml.
OLLAMA_MODELS_DIR=${HOME}/.cache/inference_engine/ollama
# Host-side path that docker-compose bind-mounts into the engine container at
# /models/ollama. Set this to wherever your ollama-style blobs+manifests live.
OLLAMA_MODELS_HOST_DIR=${HOME}/.cache/inference_engine/ollama
MLX_MODELS_DIR=${HOME}/.cache/inference_engine/mlx
VLLM_MODELS_FILE=.vllm_models.json
OPENROUTER_MODELS_FILE=.openrouter_models.json
OPENROUTER_API_KEY=sk-or-v1-REDACTED
OPENROUTER_ENDPOINT=https://openrouter.ai/api
OPENROUTER_MIN_PARAMETER_COUNT_B=50
OPENROUTER_APP_TITLE=llm-inference-engine
OPENROUTER_HTTP_REFERER=
PREFER_MLX_OVER_GGUF=true
DEFAULT_MODEL=llama3.2:3b
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
CHAT_COMPLETION_TIMEOUT_SECONDS=120
N_GPU_LAYERS=-1
N_CTX=8192
N_THREADS=0
MEMORY_BUDGET_GB=60.0
PREFIX_CACHE_BYTES=2147483648
MLX_PREFIX_CACHE_ENABLED=true
MLX_PREFIX_CACHE_MAX_SLOTS=4
LLAMA_CPP_EMBEDDING_ENABLED=true
BATCH_ENABLED=true
BATCH_MAX_WAIT_MS=10
BATCH_MAX_SIZE=32
SCHEDULER_ENABLED=true
SCHEDULER_GLOBAL_MAX_IN_FLIGHT=32
SCHEDULER_TENANT_RESERVED_IN_FLIGHT=2
SCHEDULER_RESOURCE_MAX_IN_FLIGHT=1
SCHEDULER_VLLM_RESOURCE_MAX_IN_FLIGHT=8
SCHEDULER_MAX_QUEUE_PER_TENANT=64
SCHEDULER_QUEUE_TIMEOUT_SECONDS=30
SCHEDULER_RETRY_AFTER_SECONDS=2
SCHEDULER_WAIT_AGING_PRIORITY_PER_SECOND=0.5
SCHEDULER_TENANT_FAIRNESS_WEIGHT=2.0
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=inference-engine
# Bearer-token auth. STRONGLY recommended before exposing a public endpoint
# (see docs/PUBLIC_ENDPOINT.md + `make share`): a public URL with auth off is
# an open, unauthenticated LLM. Set true, then populate AUTH_KEYS_FILE.
AUTH_ENABLED=false
AUTH_KEYS_FILE=.auth_keys.json
AUTO_EVAL_POLICIES_FILE=.auto_eval_policies.json
TOOL_AUDIT_ENABLED=true
TOOL_AUDIT_MAX_PAYLOAD_CHARS=1024
TOOL_TIMING_TTL_SECONDS=300
TOOL_TIMING_MAX_ENTRIES=10000
