        "expr": "sum by (prometa_tenant) (rate(traces_spanmetrics_calls_total{span_name=~\"chat\\\\..*|completions\\\\.run|embeddings\\\\.run|rerank\\\\.run\"}[5m]))",
        "legendFormat": "{{prometa_tenant}}",
        "refId": "A"
