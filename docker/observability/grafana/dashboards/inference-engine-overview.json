{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Traffic overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100, "collapsed": false, "panels": []
    },
    {
      "type": "stat",
      "title": "Requests / sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "targets": [{
        "expr": "sum(rate(traces_spanmetrics_calls_total{span_name=~\"chat\\\\..*|completions\\\\.run|embeddings\\\\.run|rerank\\\\.run|eval\\\\.run\"}[5m]))",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2}}
    },
    {
      "type": "stat",
      "title": "Active tenants (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "targets": [{
        "expr": "count(count by (prometa_tenant) (rate(traces_spanmetrics_calls_total[5m]) > 0))",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}}
    },
    {
      "type": "stat",
      "title": "Active models (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "targets": [{
        "expr": "count(count by (gen_ai_request_model) (rate(traces_spanmetrics_calls_total{gen_ai_request_model!=\"unknown\"}[5m]) > 0))",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}}
    },
    {
      "type": "stat",
      "title": "Error rate (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "targets": [{
        "expr": "sum(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_spanmetrics_calls_total[5m])), 0.001)",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.05}
          ]}
        }
      }
    },

    {
      "type": "row",
      "title": "Request rate breakdowns",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101, "collapsed": false, "panels": []
    },
    {
      "type": "timeseries",
