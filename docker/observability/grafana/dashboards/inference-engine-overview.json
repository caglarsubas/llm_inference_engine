    {
      "type": "stat",
      "title": "Avg req/s (dashboard range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{span_name=~\"chat[.].*|completions[.]run|embeddings[.]run|rerank[.]run|eval[.]run\"}[${__range}])) / (${__range_s})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        }
      }
    },
