        {"expr": "histogram_quantile(0.50, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket[5m])))", "legendFormat": "p50 — {{span_name}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket[5m])))", "legendFormat": "p95 — {{span_name}}", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket[5m])))", "legendFormat": "p99 — {{span_name}}", "refId": "C"}
