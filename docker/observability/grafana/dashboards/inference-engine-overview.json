      "id": 5,
      "targets": [{
        "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total[5m]))",
        "legendFormat": "{{span_name}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["last","max","mean"]}}
