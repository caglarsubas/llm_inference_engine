        "expr": "sum by (gen_ai_system) (rate(traces_spanmetrics_calls_total{span_name=~\"chat\\\\..*|completions\\\\.run|embeddings\\\\.run|rerank\\\\.run\",gen_ai_system!=\"unknown\"}[5m]))",
        "legendFormat": "{{gen_ai_system}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["last","max","mean"]}}
