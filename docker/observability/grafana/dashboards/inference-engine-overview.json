        "expr": "sum by (gen_ai_request_model) (rate(traces_spanmetrics_calls_total{span_name=~\"chat\\\\..*|completions\\\\.run|embeddings\\\\.run|rerank\\\\.run\",gen_ai_request_model!=\"unknown\"}[5m]))",
        "legendFormat": "{{gen_ai_request_model}}",
