      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[${__range}])) / clamp_min(sum(increase(traces_spanmetrics_calls_total[${__range}])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
