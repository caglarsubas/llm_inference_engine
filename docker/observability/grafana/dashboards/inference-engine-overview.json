    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 by route",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 25},
      "id": 9,
